{
  "name": "elevenlabs",
  "type": "cloud",
  "displayName": "ElevenLabs",
  "description": "Premium AI voices with voice cloning. Free tier: 10K chars/month. 29 languages.",
  "urls": {
    "synthesize": "https://api.elevenlabs.io/v1/text-to-speech/{voice}/stream",
    "voices": "https://api.elevenlabs.io/v1/voices"
  },
  "auth": {
    "type": "api-key",
    "header": "xi-api-key"
  },
  "requestFormat": {
    "bodyTemplate": "{\"text\":\"{text}\",\"model_id\":\"eleven_multilingual_v2\",\"voice_settings\":{\"stability\":0.5,\"similarity_boost\":0.75}}"
  },
  "responseFormat": {
    "audioField": "raw"
  },
  "timeout": 30000,
  "tags": ["premium", "multilingual", "cloning", "english"],
  "pricing": "https://elevenlabs.io/pricing",
  "author": "ForReading",
  "version": "1.0.0"
}
